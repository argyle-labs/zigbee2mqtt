# Proxmox LXC config for Zigbee2MQTT — /etc/pve/lxc/<vmid>.conf
#
# Service: Zigbee2MQTT (Zigbee coordinator bridge -> MQTT)
# Port:    8080 (web UI / frontend)
# Requires: a USB Zigbee coordinator (e.g. Sonoff ZBDongle, ConBee) passed
#           through from the host — see the device section below.
#
# Right-sized as captured from a live host: 1 core / 256 MB RAM / 1 GB disk,
# running on an Alpine template (very small footprint).

arch: amd64
cores: 1
memory: 256
swap: 512
hostname: zigbee2mqtt
ostype: alpine
onboot: 1
features: nesting=1
rootfs: local-lvm:vm-<vmid>-disk-0,size=1G

# Network — replace with your LAN addressing (or use ip=dhcp).
# hwaddr is auto-assigned by Proxmox on create; do not hard-code one.
net0: name=eth0,bridge=vmbr0,ip=10.0.0.19/24,gw=10.0.0.1,ip6=dhcp,type=veth

# Bind mounts (host must have these paths available)
mp0: /mnt/<pool>/backups/services/zigbee2mqtt,mp=/mnt/backups
mp1: /var/lib/zigbee2mqtt,mp=/etc/zigbee2mqtt

timezone: America/Adak
tags: alpine;community-script;mqtt;smarthome;zigbee

# ─── USB Zigbee coordinator passthrough ───────────────────────────────────────
# The host was set up with a stable udev symlink /dev/zigbee -> the coordinator's
# tty (recommended so the device survives reboots/re-plugging). Create it on the
# host with a udev rule keyed on the dongle's serial, e.g.:
#   SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{serial}=="<serial>", SYMLINK+="zigbee"
# Then allow the char devices and bind the node into the CT as /dev/ttyUSB0:
lxc.cgroup2.devices.allow: c 188:* rwm
lxc.cgroup2.devices.allow: c 189:* rwm
lxc.mount.entry: /dev/zigbee dev/ttyUSB0 none bind,optional,create=file
